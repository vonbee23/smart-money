# Mongo connection. For local dev: mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=smart_money

# Comma-separated origins allowed to call this API (frontend URL)
CORS_ORIGINS=http://localhost:5173

# SEC EDGAR requires a descriptive User-Agent with contact info for all requests
SEC_USER_AGENT=SmartMoneyApp contact@example.com

# Minutes between automatic background refreshes
REFRESH_INTERVAL_MINUTES=15
